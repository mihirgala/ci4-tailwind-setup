# CodeIgniter 4 Specific
.env
/vendor/
/writable/*
!/writable/.htaccess
!/writable/index.html

# Keep directory structures in writable
!/writable/cache/
!/writable/debugbar/
!/writable/logs/
!/writable/session/
!/writable/uploads/

/writable/cache/*
!/writable/cache/index.html
/writable/debugbar/*
!/writable/debugbar/index.html
/writable/logs/*
!/writable/logs/index.html
/writable/session/*
!/writable/session/index.html
/writable/uploads/*
!/writable/uploads/index.html

# Node.js / Frontend
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swo
*.swp

# OS generated files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
